TREND_OPENAI_API_KEY=your_openai_key_here
TREND_DEEPSEEK_API_KEY=your_deepseek_key_here

TREND_TELEGRAM_AGENT=1
TREND_LLM_CHAT=1
TREND_LLM_CHAT_TIMEOUT_S=300
TREND_CHAT_PROVIDER=openai
TREND_SUMMARY_PROVIDER=openai
TREND_OPENAI_CHAT_MODEL=gpt-4o-mini
TREND_OPENAI_SUMMARY_MODEL=gpt-4o-mini
# Optional controller override; defaults to cloud/openai if unset.
# TREND_CONTROLLER_PROVIDER=openai
# TREND_OPENAI_CONTROLLER_MODEL=gpt-4o-mini
